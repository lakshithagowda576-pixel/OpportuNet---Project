{
  "extends": "../../tsconfig.base.json",
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "**/*.test.ts"
  ],
  "compilerOptions": {
    "noEmit": true,
    "jsx": "preserve",
    "lib": [
      "esnext",
      "dom",
      "dom.iterable"
    ],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "types": [
      "node",
      "vite/client"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@workspace/api-zod": [
        "../../lib/api-zod/src"
      ],
      "@workspace/db/schema": [
        "../../lib/db/src/schema"
      ]
    }
  },
  "references": [
    {
      "path": "../../lib/api-client-react"
    },
    {
      "path": "../../lib/api-zod"
    },
    {
      "path": "../../lib/db"
    }
  ]
}